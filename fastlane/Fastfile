default_platform(:ios)

platform :ios do
  SCHEME = "Proyecto1"
  WORKSPACE = "Proyecto1.xcworkspace"
  CONFIGURATION = "Debug"
  OUTPUT_DIR = "build"
  EXPORT_METHOD = "ad-hoc"

  def generate_with_profile(profile)
    sh("tuist install")
    sh("tuist generate --configuration #{CONFIGURATION} --cache-profile #{profile}")
  end

  desc "Compila el proyecto generado por Tuist sin usar cache binaria"
  lane :build do
    generate_with_profile("none")

    sh(
      "bash",
      "-lc",
      [
        "set -o pipefail",
        "xcodebuild",
        "-workspace #{WORKSPACE}",
        "-scheme #{SCHEME}",
        "-configuration #{CONFIGURATION}",
        "-destination 'generic/platform=iOS Simulator'",
        "CODE_SIGNING_ALLOWED=NO",
        "SWIFT_VERSION=5.0",
        "clean",
        "build | xcbeautify"
      ].join(" ")
    )
  end

  desc "Compila el proyecto generado por Tuist usando module cache"
  lane :build_with_cache do
    sh("tuist install")
    sh("tuist generate --configuration #{CONFIGURATION} --cache-profile none")

    sh(
      "bash",
      "-lc",
      [
        "set -o pipefail",
        "xcodebuild",
        "-workspace #{WORKSPACE}",
        "-scheme #{SCHEME}",
        "-configuration #{CONFIGURATION}",
        "-destination 'generic/platform=iOS Simulator'",
        "CODE_SIGNING_ALLOWED=NO",
        "SWIFT_VERSION=5.0",
        "clean",
        "build | xcbeautify"
      ].join(" ")
    )
  end

  desc "Genera IPA firmado usando fuentes, no cache binaria"
  lane :build_ipa do
    generate_with_profile("none")

    build_ios_app(
      workspace: WORKSPACE,
      scheme: SCHEME,
      configuration: CONFIGURATION,
      clean: true,
      export_method: EXPORT_METHOD,
      output_directory: OUTPUT_DIR,
      output_name: "Proyecto1.ipa",
      include_bitcode: false,
      include_symbols: true,
      silent: false
    )
  end
end
